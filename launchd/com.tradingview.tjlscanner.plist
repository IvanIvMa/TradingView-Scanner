<!--
  Scanner B — TJL Entry Signals
  Runs Mon-Fri every 30 min from 16:00-20:00 Berlin (= 10:00-14:00 ET)

  Install:
    1. Replace __HOME__ with your home directory (e.g. /Users/yourname)
    2. Replace __PYTHON_PATH__ with: dirname $(which python3)
    3. cp this file ~/Library/LaunchAgents/
    4. launchctl load ~/Library/LaunchAgents/com.tradingview.tjlscanner.plist
-->
