<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.tradingview.startup</string>
    <!-- Startet TradingView Desktop bei jedem User-Login mit dem CDP-Debug-Port,
         damit der MCP-Pfad nie unbemerkt auf yfinance zurueckfaellt. -->
    <key>ProgramArguments</key>
    <array>
        <string>/bin/bash</string>
        <string>/Users/ivan/tradingviewscanner/start_tradingview.sh</string>
    </array>
    <key>RunAtLoad</key>
    <true/>
    <key>StandardOutPath</key>
    <string>/Users/ivan/tradingviewscanner/launchd_startup_stdout.log</string>
    <key>StandardErrorPath</key>
    <string>/Users/ivan/tradingviewscanner/launchd_startup_stderr.log</string>
    <key>EnvironmentVariables</key>
    <dict>
        <key>PATH</key>
        <string>/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/Library/Frameworks/Python.framework/Versions/3.14/bin</string>
    </dict>
</dict>
</plist>
